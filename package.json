{
  "name": "yira",
  "version": "0.1.0",
  "productName": "Yira",
  "description": "Infinite canvas terminal workspace for Windows",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SaGgaSsa/yira.git"
  },
  "type": "module",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build:main": "node ./scripts/electron-vite-build.mjs main",
    "build:preload": "node ./scripts/electron-vite-build.mjs preload",
    "build:renderer": "node ./scripts/electron-vite-build.mjs renderer",
    "build": "node ./scripts/electron-vite-build.mjs all",
    "dist:win": "npm run build && electron-builder --win --publish never",
    "release:win": "npm run build && electron-builder --win --publish always",
    "preview": "electron-vite preview",
    "postinstall": "electron-rebuild -f -w node-pty"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@electron/rebuild": "^4.0.3",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.0",
    "electron-vite": "^3.0.0",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "lucide-react": "^0.468.0",
    "node-pty": "^1.1.0",
    "zustand": "^5.0.0"
  },
  "build": {
    "appId": "com.yira.app",
    "productName": "Yira",
    "directories": {
      "buildResources": "resources",
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "package.json"
    ],
    "asar": true,
    "artifactName": "${productName}-Setup-${version}-${arch}.${ext}",
    "publish": [
      {
        "provider": "github",
        "owner": "SaGgaSsa",
        "repo": "yira",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
